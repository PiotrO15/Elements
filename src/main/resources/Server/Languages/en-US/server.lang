items.Essence_Collector_Harvest.name = Harvest-Attuned Essence Collector
items.Essence_Collector_Harvest.description = Absorbs Essence of the Harvest emitted by breaking mature crops.
interactionHints.Essence_Jar = Press [{key}] to store or extract essence

items.Rooted_Workbench.name = Rooted Workbench
items.Rooted_Workbench.description = A workbench that can be used to craft items used for elemental magic.

items.Rootbound_Nexus.name = Rootbound Nexus
items.Rootbound_Nexus.description = An altar capable of creating useful items from items and essence. Used together with Rootbound Pedestals and a Rootbound Wand to trigger a ritual.
