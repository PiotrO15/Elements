items.Earth_Essence.name = Essence of Earth
items.Earth_Essence.description = The main component of soil and rocks found all around Orbis. While it's one of the most common essence types, it can still be incredibly useful.
items.Harvest_Essence.name = Essence of the Harvest
items.Harvest_Essence.description = A rare essence type that can only be found during crop harvest. Since it's very volatile, complex equipment is required to collect even the smallest amounts of this essence.

items.Alchemical_Furnace.name = Alchemical Furnace
items.Alchemical_Furnace.description = A furnace that can break down items into pure essence.
